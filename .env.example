# Prismic Configuration (Public - exposed to browser)
VITE_PRISMIC_API_ENDPOINT=[Prismic API Endpoint]

# Supabase Configuration (Public - exposed to browser)
VITE_SUPABASE_URL=[Supabase URL]
VITE_SUPABASE_ANON_KEY=[Supabase Anon Key]

# Brevo Email Service (Server-side only - NOT exposed to browser)
# This should be set in Netlify Dashboard under Site settings > Environment variables
# DO NOT prefix with VITE_ as it should remain server-side only
BREVO_API_KEY=[Brevo API Key]

# Google Sheets Integration (Server-side only - NOT exposed to browser)
# These should be set in Netlify Dashboard under Site settings > Environment variables
# Service Account Email from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=[Service Account Email]
# Private Key from Service Account JSON (keep the \n characters for line breaks)
GOOGLE_PRIVATE_KEY=[Private Key with \n]
# Google Sheet ID from the spreadsheet URL
GOOGLE_SHEET_ID=[Sheet ID]

# Supabase Service Role Key (Server-side only - NOT exposed to browser)
# Used by Netlify functions to bypass RLS (e.g., unsubscribe without login)
# Find in: Supabase Dashboard > Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=[Supabase Service Role Key]

# Prismic Webhook Secret (Server-side only)
# A random string you generate to verify webhook requests from Prismic
# Generate with: openssl rand -hex 32
PRISMIC_WEBHOOK_SECRET=[Random Secret String]